---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ConversionBanner from '../../components/ConversionBanner.astro';
import { site } from '../../data/site';

const faqItems = [
  { id: 'faq-1', q: 'Quels sont vos tarifs pour une location de bus ?', a: 'Nos tarifs varient selon la durée, la distance et le type de véhicule. Un bus standard de 50 places coûte entre 300 et 950 euros par jour. Contactez-nous pour un devis personnalisé.' },
  { id: 'faq-2', q: 'Comment réserver un bus avec chauffeur ?', a: 'Contactez-nous par téléphone au +32 2 446 01 91 ou par email à info@locationbus.be. Nous vous fournirons un devis détaillé sous 24h.' },
  { id: 'faq-3', q: 'Quelles sont vos zones de service ?', a: 'Nous desservons Bruxelles, toute la Belgique et l\'Europe. Nos destinations populaires incluent Paris, Amsterdam, Frankfurt et Rotterdam.' },
  { id: 'faq-4', q: 'Vos véhicules sont-ils assurés ?', a: 'Oui, tous nos véhicules sont entièrement assurés et nos chauffeurs sont expérimentés et certifiés.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: site.name,
    telephone: site.phone,
    email: site.email,
    address: { '@type': 'PostalAddress', streetAddress: 'Pegasuslaan 5', addressLocality: 'Machelen', postalCode: '1831', addressCountry: 'BE' },
  },
};

const jsonLd = [faqSchema, contactSchema];
---

<BaseLayout
  title="Contact LocationBus | Devis Gratuit Location Bus Bruxelles"
  description="Contactez LocationBus pour un devis gratuit. 7j/7, sans engagement. Réponse sous 24h. +32 2 446 01 91."
  canonicalUrl="/contact/"
  jsonLd={jsonLd}
  lang="fr"
>
  <Header />
  <main id="main">
    <section class="hero">
      <div class="container">
        <h1>Contactez-Nous</h1>
        <p>Devis gratuit, sans engagement. Réponse garantie sous 24h.</p>
      </div>
    </section>

    <ConversionBanner />

    <section>
      <div class="container">
        <div class="grid-2">
          <div>
            <h2>Informations de Contact</h2>
            <p><strong>Téléphone:</strong> <a href={site.phoneTel}>{site.phone}</a></p>
            <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
            <p><strong>Adresse:</strong> {site.address}</p>
            <p>{site.cta.service247}</p>
          </div>
          <div>
            <h2>Demander un Devis</h2>
            <form action="mailto:info@locationbus.be" method="post" enctype="text/plain" aria-labelledby="form-title">
              <p id="form-title" class="visually-hidden">Formulaire de demande de devis</p>
              <p>
                <label for="contact-name">Votre nom</label><br />
                <input type="text" id="contact-name" name="name" required class="form-input" />
              </p>
              <p>
                <label for="contact-email">Votre email</label><br />
                <input type="email" id="contact-email" name="email" required class="form-input" />
              </p>
              <p>
                <label for="contact-message">Message</label><br />
                <textarea id="contact-message" name="message" rows="5" required class="form-input"></textarea>
              </p>
              <button type="submit" class="btn">Envoyer</button>
            </form>
          </div>
        </div>

        <h2>Questions Fréquentes</h2>
        <div>
          {faqItems.map((item) => (
            <article id={item.id}>
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
