---
import { site, footerLinks } from '../data/site';
---

<footer role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src="/logo.png" alt="LocationBus" width="120" height="40" />
        <p><strong>{site.name}</strong> – {site.tagline}</p>
        <p>{site.address}</p>
        <p><a href={site.phoneTel}>{site.phone}</a> · <a href={`mailto:${site.email}`}>{site.email}</a></p>
        <p class="footer-cta">{site.cta.devis} · {site.cta.service247} · {site.cta.sansEngagement}</p>
      </div>
      <div>
        <h3 id="footer-services">Services</h3>
        <ul aria-labelledby="footer-services">
          {footerLinks.services.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 id="footer-bruxelles">Location bus Bruxelles</h3>
        <ul aria-labelledby="footer-bruxelles">
          {footerLinks.bruxelles.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 id="footer-aeroports">Aéroports</h3>
        <ul aria-labelledby="footer-aeroports">
          {footerLinks.aeroports.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
        <p><a href={footerLinks.contact.href}>{footerLinks.contact.label}</a></p>
      </div>
    </div>
    <p class="footer-copy">© 2025 {site.name}. Tous droits réservés.</p>
  </div>
</footer>
