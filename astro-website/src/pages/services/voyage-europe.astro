---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ConversionBanner from '../../components/ConversionBanner.astro';
import { site } from '../../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Voyage Bus Europe - LocationBus',
  description: 'Voyages longue distance en bus vers Paris, Amsterdam, Frankfurt',
  provider: { '@type': 'Organization', name: site.name, url: site.url },
};
---

<BaseLayout
  title="Voyage Bus Europe | Paris, Amsterdam, Frankfurt | LocationBus"
  description="Voyages en bus longue distance vers Paris, Amsterdam, Frankfurt, Rotterdam. Devis gratuit, 7j/7, sans engagement."
  canonicalUrl="/services/voyage-europe/"
  jsonLd={jsonLd}
  lang="fr"
>
  <Header />
  <main id="main">
    <section class="hero">
      <div class="container">
        <h1>Voyage Bus Europe</h1>
        <p>Voyages confortables pour vos déplacements longue distance en Europe.</p>
        <p><a href="/contact/" class="btn">{site.cta.devisLong}</a></p>
      </div>
    </section>
    <ConversionBanner />
    <section>
      <div class="container">
        <h2>Destinations Populaires</h2>
        <p>Paris, Amsterdam, Frankfurt, Rotterdam et toute l'Europe. Autocars confortables, chauffeurs expérimentés.</p>
        <p><a href="/location-bus-bruxelles/">Location bus Bruxelles</a> · <a href="/services/">Tous nos services</a></p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
