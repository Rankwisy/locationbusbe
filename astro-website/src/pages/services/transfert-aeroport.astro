---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/content';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Transfert Bus Aéroport Bruxelles - LocationBus',
  description: 'Transferts bus vers Brussels Airport Zaventem et Brussels South Charleroi',
  provider: { '@type': 'Organization', name: 'LocationBus', url: site.url },
};
---

<BaseLayout
  title="Transfert Bus Aéroport Bruxelles | Zaventem & Charleroi - LocationBus"
  description="Transferts bus professionnels vers Brussels Airport (Zaventem) et Brussels South (Charleroi). Groupes et événements. Bruxelles, Machelen, Zaventem. Devis gratuit."
  canonicalUrl="/services/transfert-aeroport/"
  jsonLd={jsonLd}
  lang="fr"
>
  <Header />
  <main id="main">
    <section class="hero">
      <div class="container">
        <h1>Transfert Bus Aéroport Bruxelles</h1>
        <p>Transferts directs vers Brussels Airport (Zaventem) et Brussels South (Charleroi). Service groupe professionnel.</p>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Aéroports Desservis</h2>
        <div class="grid-2">
          <article class="card">
            <h3>Brussels Airport (Zaventem)</h3>
            <p>Transferts vers et depuis Brussels Airport, le principal aéroport de Belgique. Idéal pour groupes, entreprises, événements.</p>
          </article>
          <article class="card">
            <h3>Brussels South Charleroi</h3>
            <p>Transferts vers Charleroi Airport. Liaisons régulières depuis Bruxelles et la Belgique.</p>
          </article>
        </div>
        <p><a href="/contact/" class="btn">Demander un Devis</a></p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
