---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/content';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Location Bus Transfert - LocationBus',
  description: 'Service de transfert bus professionnel pour groupes',
  provider: { '@type': 'Organization', name: 'LocationBus', url: site.url },
};
---

<BaseLayout
  title="Location Bus Transfert pour Groupes | LocationBus Bruxelles"
  description="Service de transfert bus professionnel pour tous vos déplacements en groupe. Bruxelles, Belgique, Europe. Événements, séminaires, sorties."
  canonicalUrl="/services/transfert-bus/"
  jsonLd={jsonLd}
  lang="fr"
>
  <Header />
  <main id="main">
    <section class="hero">
      <div class="container">
        <h1>Location Bus Transfert</h1>
        <p>Service de transfert professionnel pour tous vos déplacements en groupe.</p>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Transferts Sur Mesure</h2>
        <p>Que ce soit pour un événement d'entreprise, une sortie scolaire ou un déplacement privé, nous organisons votre transfert de A à Z.</p>
        <p><a href="/contact/" class="btn">Obtenir un Devis</a></p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
