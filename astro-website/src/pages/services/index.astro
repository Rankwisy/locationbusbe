---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ConversionBanner from '../../components/ConversionBanner.astro';
import { site } from '../../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Location de Bus avec Chauffeur - Services LocationBus',
  provider: { '@type': 'Organization', name: site.name, url: site.url },
  areaServed: ['Bruxelles', 'Belgique', 'Europe'],
};
---

<BaseLayout
  title="Nos Services de Location de Bus | LocationBus Bruxelles"
  description="Location de bus avec chauffeur : transferts aéroport, voyages Europe, événements. Bruxelles, Belgique, Europe. Devis gratuit, 7j/7, sans engagement."
  canonicalUrl="/services/"
  jsonLd={jsonLd}
  lang="fr"
>
  <Header />
  <main id="main">
    <section class="hero">
      <div class="container">
        <h1>Nos Services de Transport</h1>
        <p>Location de bus avec chauffeur pour tous vos déplacements en groupe à Bruxelles, en Belgique et en Europe.</p>
        <p><a href="/contact/" class="btn">{site.cta.devisLong}</a></p>
      </div>
    </section>
    <ConversionBanner />
    <section>
      <div class="container">
        <h2>Services Disponibles</h2>
        <div class="grid-3">
          <article class="card">
            <h3>Location Bus Transfert</h3>
            <p>Service de transfert professionnel pour déplacements en groupe. Idéal pour événements, sorties scolaires, séminaires.</p>
            <a href="/services/transfert-bus/">Détails</a>
          </article>
          <article class="card">
            <h3>Transfert Aéroport</h3>
            <p>Transferts directs vers Brussels Airport (Zaventem) et Brussels South (Charleroi). Prise en charge et retour garantis.</p>
            <a href="/services/transfert-aeroport/">Détails</a> · <a href="/services/transfert-aeroport/zaventem/">Zaventem</a> · <a href="/services/transfert-aeroport/charleroi/">Charleroi</a>
          </article>
          <article class="card">
            <h3>Voyage Europe</h3>
            <p>Voyages longue distance vers Paris, Amsterdam, Frankfurt, Rotterdam et toute l'Europe.</p>
            <a href="/services/voyage-europe/">Détails</a>
          </article>
        </div>
        <h2>Location Bus par Commune</h2>
        <p><a href="/location-bus-bruxelles/">Voir toutes les communes de Bruxelles</a></p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
