---
const currentPath = Astro.url.pathname;
---

<header>
  <div class="container">
    <nav>
      <a href="/" aria-label="LocationBus Accueil">
        <strong>LocationBus</strong>
      </a>
      <a href="/services/" class={currentPath.startsWith('/services') ? 'active' : ''}>Services</a>
      <a href="/about/" class={currentPath.startsWith('/about') ? 'active' : ''}>À Propos</a>
      <a href="/contact/" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a>
      <a href="tel:+3224460191">+32 2 446 01 91</a>
    </nav>
  </div>
</header>
