---
import { nav } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header role="banner">
  <div class="container">
    <nav aria-label="Navigation principale">
      <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>
        <strong>LocationBus</strong>
      </a>
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <a href="tel:+3224460191">+32 2 446 01 91</a>
    </nav>
  </div>
</header>
