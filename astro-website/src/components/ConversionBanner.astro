---
import { site } from '../data/site';
---

<section class="conversion-banner" aria-label="Avantages et appel à l'action">
  <div class="container">
    <p class="conversion-banner__text">
      <span>{site.cta.devis}</span>
      <span aria-hidden="true"> · </span>
      <span>{site.cta.service247}</span>
      <span aria-hidden="true"> · </span>
      <span>{site.cta.sansEngagement}</span>
    </p>
    <p class="conversion-banner__cta">
      <a href="/contact/" class="btn">{site.cta.devisLong}</a>
    </p>
  </div>
</section>
